---
import { getCollection, type CollectionEntry } from "astro:content";
import { render } from "astro:content"; // 1. Import the new render function
import ProjectLayout from "../../layouts/ProjectLayout.astro";

export async function getStaticPaths() {
  const projectEntries = await getCollection("projects", ({ data }) => {
    return data.draft !== true;
  });
  
  return projectEntries.map(entry => ({
    params: { slug: entry.id }, // 2. Changed entry.slug to entry.id
    props: { entry },
  }));
}

// Explicitly type the props
interface Props {
  entry: CollectionEntry<"projects">;
}

// Destructure the typed entry
const { entry } = Astro.props;

// 3. Render the content using the new top-level render function
const { Content } = await render(entry);
---

<ProjectLayout {...entry.data}>
  <Content />
</ProjectLayout>